# ── AI-Driven Infrastructure Anomaly Detector ──────────────────
# Copy this file: cp .env.example .env
# Then fill in the values for your environment.

# ── Service ──────────────────────────────────────────────────────
SERVICE_ENV=development
SERVICE_PORT=8000

# ── Authentication ───────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=anomaly_detector
POSTGRES_USER=anomaly
POSTGRES_PASSWORD=

# ── InfluxDB ────────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=anomaly-detector
INFLUXDB_BUCKET=metrics

# ── Prometheus ───────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── Alert Channels ──────────────────────────────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=

# ── Email (SMTP) ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=

# ── Grafana ─────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Kafka (optional) ────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=infrastructure-metrics
