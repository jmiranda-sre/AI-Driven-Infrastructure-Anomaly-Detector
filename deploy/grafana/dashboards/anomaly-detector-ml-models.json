{
  "annotations": {
    "list": []
  },
  "description": "ML model performance, drift status, and training metrics for the Anomaly Detector",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(ml_inference_duration_seconds_bucket[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ml_inference_duration_seconds_bucket[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p99",
          "refId": "B"
        }
      ],
      "title": "Model Inference Latency (p50 vs p99)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(anomaly_detections_total[5m])) by (server_id)",
          "legendFormat": "{{server_id}}",
          "refId": "A"
        }
      ],
      "title": "Detections per Server",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(anomaly_detections_total) by (severity)",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ],
      "title": "Cumulative Detections by Severity (Pie)",
      "type": "piechart"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{endpoint=~\".*train.*|.*drift.*\"}[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "Training and Drift API Calls",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.25
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "0",
          "legendFormat": "PSI (placeholder)",
          "refId": "A"
        }
      ],
      "title": "Drift Score (PSI)",
      "type": "gauge"
    },
    {
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Stale",
                  "color": "red"
                },
                "1": {
                  "text": "Active",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 16
      },
      "targets": [
        {
          "expr": "1",
          "legendFormat": "model_status",
          "refId": "A"
        }
      ],
      "title": "Model Status",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "anomaly-detector",
    "ml",
    "models"
  ],
